// corridor — a 2.5D traversal corridor that exercises the **Rail2.5D** camera
// (issue #23 deferred → #27). Pacing-wise the *rest* between arena tension
// peaks (#27 Locked: "2.5D traversal corridors are rest").
//
// The corridor runs along world **X** (the rail axis); the rail centreline is
// world **Z = 0**. Rail2.5D tracks the avatar's X but **locks** the camera depth
// to the rail (fixed Z = `dist`), so depth wobble never swings the camera —
// "can't fall the wrong way". `pitch` is gentler than the arena's 3/4 follow so
// the framing reads side-on (a flat platforming plane) rather than top-down.
//
// `role` is opaque to the engine; `src/main.rs`'s `specialize_scene` maps it to
// gameplay components. Positions are world (x, height, z); ground is the XZ
// plane (Y-up). For avatar / enemy / landmark only rotation + scale on the
// transform are load-bearing (x, z seed a `WorldPos`).
Space(
    // Side-on rail: ~1.4 up, locked 2.4 in front (Z), tilted down a touch.
    camera: Rail2_5D(height: 1.4, dist: 2.4, pitch: -0.35),

    instances: [
        // Avatar enters at the left mouth of the corridor.
        Instance(
            mesh: Some("teapot"),
            role: "avatar",
            pos: (-1.8, 0.0, 0.0),
            rot: (-1.5708, 0.0, 0.0),
            scale: (0.11, 0.11, 0.11),
            material: Some((diffuse: (110, 180, 235), ambient: (26, 40, 58))),
        ),
        // A lone patroller pacing the corridor along X (a light threat on the
        // rest beat, not an arena encounter). path[0] == spawn.
        Instance(
            mesh: Some("cube"),
            role: "enemy",
            pos: (1.6, 0.0, 0.0),
            rot: (0.0, 0.4, 0.0),
            scale: (0.16, 0.16, 0.16),
            material: Some((diffuse: (225, 80, 70), ambient: (56, 20, 18))),
            path: [(1.6, 0.0), (0.4, 0.0)],
        ),
        // Walls / props lining the rail, spaced along X to give the side-on
        // framing depth cues and parallax as the avatar walks past.
        Instance(
            mesh: Some("cube"),
            role: "landmark",
            pos: (-0.8, 0.0, -0.5),
            rot: (0.0, 0.0, 0.0),
            scale: (0.16, 0.16, 0.16),
            material: Some((diffuse: (120, 120, 138), ambient: (34, 34, 44))),
        ),
        Instance(
            mesh: Some("cube"),
            role: "landmark",
            pos: (0.6, 0.0, -0.5),
            rot: (0.0, 0.3, 0.0),
            scale: (0.16, 0.16, 0.16),
            material: Some((diffuse: (120, 120, 138), ambient: (34, 34, 44))),
        ),
    ],

    // Back to the atrium arena (a real neighbour now exists — see atrium.ron).
    exits: [
        Exit(to: "atrium", at: (-2.0, 0.0, 0.0)),
    ],
)
